---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import Button from '../../components/ui/Button.astro';
import ProductCard from '../../components/products/ProductCard.astro';
import PostCard from '../../components/blog/PostCard.astro';
import translations from '../../i18n/zh.json';

const featuredProducts = await getCollection('products', ({ id, data }) => {
  return id.startsWith('zh/') && data.featured;
}).then(products => products.slice(0, 3));

const latestPosts = await getCollection('posts', ({ id }) => {
  return id.startsWith('zh/');
}).then(posts => posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)
);

const t = translations;
---

<Layout title="首页 - My Site" description={t.home.hero.subtitle}>
  <Navbar lang="zh" />

  <main>
    <!-- Hero Section -->
    <section class="relative min-h-[90vh] flex items-center overflow-hidden">
      <!-- Background Effects -->
      <div class="absolute inset-0 bg-gradient-hero">
        <div class="absolute inset-0 bg-gradient-mesh"></div>
      </div>

      <!-- Decorative Elements -->
      <div class="absolute top-20 left-10 w-72 h-72 bg-primary/20 rounded-full blur-3xl animate-pulse-glow"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent/30 rounded-full blur-3xl animate-pulse-glow" style="animation-delay: 2s;"></div>

      <!-- Floating Cards Decoration -->
      <div class="absolute top-1/4 right-[15%] hidden lg:block">
        <div class="glass glass-border rounded-2xl p-4 animate-float shadow-xl" style="animation-delay: 0s;">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary">
                <path d="M12 2v20M2 12h20"/>
              </svg>
            </div>
            <div>
              <div class="text-sm font-semibold">新品上市</div>
              <div class="text-xs text-muted-foreground">每日更新</div>
            </div>
          </div>
        </div>
      </div>

      <div class="absolute bottom-1/3 left-[10%] hidden lg:block">
        <div class="glass glass-border rounded-2xl p-4 animate-float shadow-xl" style="animation-delay: 1.5s;">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-green-500/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-green-600">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <div>
              <div class="text-sm font-semibold">品质保证</div>
              <div class="text-xs text-muted-foreground">100% 正品</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Hero Content -->
      <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 rounded-full border bg-background/50 backdrop-blur px-4 py-1.5 mb-8 animate-fade-in">
            <span class="flex h-2 w-2 rounded-full bg-primary animate-pulse"></span>
            <span class="text-sm font-medium text-muted-foreground">专业外贸服务提供商</span>
          </div>

          <!-- Title -->
          <h1 class="mb-6 text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl xl:text-7xl animate-fade-in-up" style="animation-delay: 0.1s;">
            {t.home.hero.title}
            <span class="block mt-2 text-gradient">品质 · 创新 · 服务</span>
          </h1>

          <!-- Subtitle -->
          <p class="mb-10 text-lg text-muted-foreground sm:text-xl max-w-2xl mx-auto animate-fade-in-up" style="animation-delay: 0.2s;">
            {t.home.hero.subtitle}
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in-up" style="animation-delay: 0.3s;">
            <a
              href="/zh/products"
              class="inline-flex items-center justify-center gap-2 rounded-full btn-primary-gradient px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary/25"
            >
              {t.home.hero.cta}
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/>
                <path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
            <a
              href="/zh/about"
              class="inline-flex items-center justify-center gap-2 rounded-full border bg-background/50 backdrop-blur px-8 py-4 text-base font-semibold text-foreground transition-colors hover:bg-muted"
            >
              {t.home.hero.secondaryCta}
            </a>
          </div>

          <!-- Stats -->
          <div class="mt-16 grid grid-cols-3 gap-8 animate-fade-in-up" style="animation-delay: 0.4s;">
            <div class="text-center">
              <div class="text-3xl sm:text-4xl font-bold text-gradient">500+</div>
              <div class="mt-1 text-sm text-muted-foreground">产品种类</div>
            </div>
            <div class="text-center">
              <div class="text-3xl sm:text-4xl font-bold text-gradient">50+</div>
              <div class="mt-1 text-sm text-muted-foreground">合作国家</div>
            </div>
            <div class="text-center">
              <div class="text-3xl sm:text-4xl font-bold text-gradient">10年</div>
              <div class="mt-1 text-sm text-muted-foreground">行业经验</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Scroll Indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted-foreground">
          <path d="M12 5v14"/>
          <path d="m19 12-7 7-7-7"/>
        </svg>
      </div>
    </section>

    <!-- Featured Products -->
    <section class="py-20 lg:py-32 relative">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-12">
          <div>
            <span class="inline-block mb-3 text-sm font-semibold uppercase tracking-wider text-primary">
              精选产品
            </span>
            <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
              {t.home.featuredProducts.title}
            </h2>
            <p class="mt-2 text-muted-foreground max-w-xl">
              {t.home.featuredProducts.subtitle}
            </p>
          </div>
          <a
            href="/zh/products"
            class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:gap-3 transition-all"
          >
            {t.home.featuredProducts.viewAll}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 stagger-children">
          {featuredProducts.map((product) => (
            <ProductCard
              image={product.data.images[0] || '/images/placeholder.jpg'}
              title={product.data.name}
              description={product.data.description}
              href={`/zh/products/${product.id.replace('zh/', '')}`}
              price={product.data.price}
              category={product.data.category}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-20 lg:py-32 bg-muted/50">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <span class="inline-block mb-3 text-sm font-semibold uppercase tracking-wider text-primary">
            我们的优势
          </span>
          <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
            为什么选择我们
          </h2>
        </div>

        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
          {[
            {
              icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
              title: '品质保证',
              desc: '严格的质量控制体系，确保每一件产品都符合国际标准'
            },
            {
              icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: '价格优势',
              desc: '直接对接工厂，为您提供最具竞争力的价格'
            },
            {
              icon: 'M13 10V3L4 14h7v7l9-11h-7z',
              title: '快速交付',
              desc: '高效的物流体系，确保货物准时安全送达'
            },
            {
              icon: 'M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zM12 9v4m0 0v4m0-4h4m-4 0H8',
              title: '定制服务',
              desc: '根据客户需求提供个性化的产品定制方案'
            }
          ].map((feature, i) => (
            <div class="card-modern p-6 text-center animate-fade-in-up" style={`animation-delay: ${i * 0.1}s;`}>
              <div class="mx-auto mb-4 w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary">
                  <path d={feature.icon} stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3 class="mb-2 text-lg font-semibold">{feature.title}</h3>
              <p class="text-sm text-muted-foreground">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Latest Posts -->
    <section class="py-20 lg:py-32">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-12">
          <div>
            <span class="inline-block mb-3 text-sm font-semibold uppercase tracking-wider text-primary">
              最新动态
            </span>
            <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
              {t.home.latestPosts.title}
            </h2>
            <p class="mt-2 text-muted-foreground max-w-xl">
              {t.home.latestPosts.subtitle}
            </p>
          </div>
          <a
            href="/zh/blog"
            class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:gap-3 transition-all"
          >
            {t.home.latestPosts.readMore}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 stagger-children">
          {latestPosts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              href={`/zh/blog/${post.id.replace('zh/', '')}`}
              date={post.data.pubDate}
              tags={post.data.tags}
              coverImage={post.data.coverImage}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 lg:py-32 bg-gradient-hero relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-mesh"></div>
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-72 h-72 bg-accent/20 rounded-full blur-3xl"></div>

      <div class="relative container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold text-foreground sm:text-4xl lg:text-5xl mb-6">
          准备好开始合作了吗？
        </h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto mb-10">
          联系我们的专业团队，获取定制化解决方案和报价
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/zh/about"
            class="inline-flex items-center justify-center gap-2 rounded-full btn-primary-gradient px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary/25"
          >
            联系我们
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="zh" />
</Layout>
