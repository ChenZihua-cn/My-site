---
import { SITE } from '../../consts';

export interface Props {
  lang?: 'zh' | 'en';
}

const { lang = 'zh' } = Astro.props;
const isZh = lang === 'zh';
---

<footer class="border-t bg-muted/50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <a href={isZh ? '/zh' : '/en'} class="inline-block text-xl font-bold text-foreground hover:text-primary transition-colors mb-4">
          {isZh ? SITE.nameZh : SITE.name}
        </a>
        <p class="text-sm text-muted-foreground leading-relaxed">
          {isZh ? SITE.descriptionZh : SITE.description}
        </p>

        <!-- Social Links -->
        <div class="flex gap-3 mt-6">
          <a
            href="#"
            class="h-10 w-10 rounded-full bg-background border flex items-center justify-center text-muted-foreground hover:text-primary hover:border-primary/30 transition-all"
            aria-label="GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
              <path d="M9 18c-4.51 2-5-2-7-2"/>
            </svg>
          </a>
          <a
            href="#"
            class="h-10 w-10 rounded-full bg-background border flex items-center justify-center text-muted-foreground hover:text-primary hover:border-primary/30 transition-all"
            aria-label="Twitter"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground mb-4">
          {isZh ? '快速链接' : 'Quick Links'}
        </h3>
        <ul class="space-y-3">
          <li>
            <a href={isZh ? '/zh' : '/en'} class="text-sm text-muted-foreground hover:text-primary transition-colors">
              {isZh ? '首页' : 'Home'}
            </a>
          </li>
          <li>
            <a href={isZh ? '/zh/products' : '/en/products'} class="text-sm text-muted-foreground hover:text-primary transition-colors">
              {isZh ? '产品' : 'Products'}
            </a>
          </li>
          <li>
            <a href={isZh ? '/zh/blog' : '/en/blog'} class="text-sm text-muted-foreground hover:text-primary transition-colors">
              {isZh ? '博客' : 'Blog'}
            </a>
          </li>
          <li>
            <a href={isZh ? '/zh/about' : '/en/about'} class="text-sm text-muted-foreground hover:text-primary transition-colors">
              {isZh ? '关于我们' : 'About'}
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground mb-4">
          {isZh ? '联系方式' : 'Contact'}
        </h3>
        <div class="space-y-3">
          <a
            href={`mailto:${SITE.email}`}
            class="flex items-center gap-3 text-sm text-muted-foreground hover:text-primary transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            {SITE.email}
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-muted-foreground">
        © {new Date().getFullYear()} {isZh ? SITE.nameZh : SITE.name}. {isZh ? '保留所有权利' : 'All rights reserved'}.
      </p>
      <div class="flex items-center gap-2">
        <span class="flex h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
        <span class="text-xs text-muted-foreground">{isZh ? '系统运行正常' : 'All systems operational'}</span>
      </div>
    </div>
  </div>
</footer>
