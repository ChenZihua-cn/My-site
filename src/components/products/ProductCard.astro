---
export interface Props {
  image: string;
  title: string;
  description: string;
  href: string;
  price?: string;
  category?: string;
}

const { image, title, description, href, price, category } = Astro.props;
---

<article class="group card-modern animate-fade-in-up">
  <a href={href} class="block">
    <div class="aspect-[4/3] overflow-hidden bg-muted">
      <img
        src={image}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-110"
        loading="lazy"
      />
    </div>

    <div class="p-5">
      {category && (
        <span class="inline-block mb-3 text-xs font-semibold uppercase tracking-wider text-primary bg-primary/10 px-2.5 py-1 rounded-full">
          {category}
        </span>
      )}

      <h3 class="mb-2 text-lg font-semibold text-foreground group-hover:text-primary transition-colors">
        {title}
      </h3>

      <p class="mb-4 text-sm text-muted-foreground line-clamp-2 leading-relaxed">
        {description}
      </p>

      {price && (
        <p class="text-lg font-bold text-gradient">{price}</p>
      )}
    </div>
  </a>
</article>
